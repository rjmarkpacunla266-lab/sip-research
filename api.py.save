║              SIP — Scientific Information Puller  v4.0                 ║
╠══════════════════════════════════════════════════════════════════════════╣
║                                                                          ║
║  WHAT THIS TOOL DOES:                                                    ║
║  Searches and fetches academic research papers using the OpenAlex API,  ║
║  extracts relevant text blocks from abstracts, and exports results in   ║
║  multiple formats (JSON, CSV, BibTeX, RIS, Markdown, TXT).              ║
║                                                                          ║
║  DATA SOURCE NOTICE:                                                     ║
║  All research data is fetched from OpenAlex (https://openalex.org)      ║
║  OpenAlex is a FREE and OPEN academic database with 250M+ works.        ║
║  This tool does NOT own or store any research content.                  ║
║  All papers belong to their respective authors and publishers.          ║
║                                                                          ║
║  OpenAlex sources data from:                                             ║
║    - Crossref           - PubMed                                         ║
║    - ORCID              - Internet Archive                               ║
║    - Microsoft Academic Graph                                            ║
║                                                                          ║
║  ⚠️  REFERENCE / CITATION DISCLAIMER:                                    ║
║  References generated by this tool (APA, MLA, BibTeX, RIS) are         ║
║  AUTOMATICALLY GENERATED from API metadata and may NOT be accurate.     ║
║                                                                          ║
║  Known issues with auto-generated references:                           ║
║    - Volume, issue, page numbers are often MISSING                      ║
║    - Author names may not follow exact formatting rules                 ║
║    - Journal names may be abbreviated or wrong                          ║
║    - Some DOIs may be outdated or missing                               ║
║    - Conference papers may be misclassified                             ║
║                                                                          ║
║  ALWAYS manually verify references before academic submission.          ║
║  Cross-check with: CrossRef, publisher website, Google Scholar          ║
║                                                                          ║
║  ⚠️  COVERAGE NOTICE:                                                    ║
║  OpenAlex does NOT cover all academic papers.                           ║
║  Best coverage: STEM, Medicine, Social Sciences                         ║
║  Limited coverage: Humanities, very new papers, paywalled content       ║
║                                                                          ║
║  ⚠️  RATE LIMIT NOTICE:                                                  ║
║  OpenAlex allows 100,000 free requests per day.                         ║
║  Add your email to config.json (polite_email) for higher limits.        ║
║  Caching is enabled by default to avoid repeated requests.              ║
║                                                                          ║
╚══════════════════════════════════════════════════════════════════════════╝
"""

# ─── IMPORTS ────────────────────────────────────────────────────────────────────
# Standard Python libraries — all built-in, no installation needed
import json          # reading/writing JSON files
import re            # text pattern matching (regular expressions)
import csv           # writing CSV/spreadsheet files
import os            # file and folder operations
import time          # delays between API requests
import hashlib       # creating unique cache file names from strings
import argparse      # parsing command-line arguments
import sys           # system exit and platform info
import logging       # error and warning logging
from datetime import datetime        # timestamps for exports
from collections import defaultdict  # counting occurrences easily

# Third-party library — install with: pip install requests
import requests      # making HTTP requests to APIs


# ─── LOGGING SETUP ──────────────────────────────────────────────────────────────
# Controls what error/debug messages appear in terminal
# Change to logging.DEBUG to see all network activity
logging.basicConfig(level=logging.WARNING, format="%(levelname)s: %(message)s")
logger = logging.getLogger("sip")


# ─── LOAD CONFIG ────────────────────────────────────────────────────────────────
# Reads all settings from config.json
# Every setting has a safe default value — tool works even without config.json

def load_config():
    """
    Load configuration from config.json with safe defaults.

    HOW TO CUSTOMIZE SETTINGS:
    Edit config.json — you do NOT need to touch this code.
    All options are explained in config.json with comments.

    If config.json is missing, defaults are used and a warning is shown.
    If config.json has a syntax error, defaults are used instead of crashing.
    """
    defaults = {
        # ── API Settings ──────────────────────────────────────────────────────
        # OpenAlex works endpoint — do not change unless they change their URL
        "base_url": "https://api.openalex.org/works",

        # How many papers per page (max allowed by OpenAlex: 200)
        # Recommended: 25-50 for balance of speed and results
        "per_page": 50,

        # How many pages to fetch (total = per_page × max_pages)
        # Example: 25 × 4 = 100 papers maximum per search
        "max_pages": 4,

        # Your email address — optional but STRONGLY recommended
        # OpenAlex gives higher rate limits to tools that identify themselves
        # See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
        "polite_email": "",

        # ── Text Extraction ───────────────────────────────────────────────────
        # How to split abstract into blocks for keyword matching
        # "paragraph" = split by newlines (best for most cases)
        # "sentence"  = split by period/exclamation/question mark
        # "full"      = keep entire abstract as one block
        "text_mode": "paragraph",

        # How strictly keywords must match a text block
        # "all"    = ALL keywords must be present (fewer but more relevant results)
        # "any"    = ANY single keyword is enough (more results, less precise)
        # "phrase" = keywords must appear together as exact phrase
        "match_mode": "all",

        # Minimum words a text block must contain (removes short useless sentences)
        "min_word_count": 10,

        # Minimum words an abstract must have to be processed at all
        "min_abstract_words": 20,

        # Maximum text blocks to extract from each paper's abstract
        # Increase to get more content per paper
        "max_blocks_per_source": 3,

        # ── Paper Filters ─────────────────────────────────────────────────────
        # Only include papers published within this year range
        "year_min": 2000,
        "year_max": 2026,

        # Only include papers with at least this many citations
        # Set to 0 to include all papers regardless of how many times cited
        "min_citation_count": 0,

        # Set to true to only get papers with free full text available
        "open_access_only": False,

        # Filter by language code (e.g., "en" = English, "fr" = French)
        # Leave empty to include all languages
        "language_filter": "",

        # Filter by author name (partial match)
        # Example: "Garcia" matches any paper with an author named Garcia
        "author_filter": "",

        # Filter by institution (partial match)
        # Example: "Oxford" matches papers from Oxford University
        "institution_filter": "",

        # Filter by topic/concept tags (list of strings)
        # Example: ["Machine Learning", "Deep Learning"]
        "concepts_filter": [],

        # ── Sorting ───────────────────────────────────────────────────────────
        # How OpenAlex should sort results before returning them
        # "cited_by_count:desc" = most cited papers first (RECOMMENDED)
        # "publication_date:desc" = newest papers first
        # "cited_by_count:asc" = least cited first (not recommended usually)
        "sort_by": "cited_by_count:desc",

        # ── Output & Export ───────────────────────────────────────────────────
        # Main output file (JSON format, used by index.html)
        "output_file": "output.json",

        # Formats to export — add or remove as needed
        # Available: "json", "csv", "bibtex", "ris", "markdown", "txt"
        "export_formats": ["json", "csv", "bibtex", "markdown"],

        # Whether to include the open access URL for each paper (free full text link)
        "fetch_open_access_url": True,

        # Whether to include the full reconstructed abstract in JSON output
        "include_abstract_full": True,

        # Reference style — currently "apa7" only, more styles planned
        # ⚠️  Auto-generated — always verify before academic use
        "reference_style": "apa7",

        # ── Caching ───────────────────────────────────────────────────────────
        # Cache saves API responses as files so repeated searches are instant
        # and don't waste API quota
        "cache_enabled": True,

        # Folder where cache files are stored (.cache is hidden on Linux/Mac)
        "cache_dir": ".cache",

        # How long to keep cached responses before fetching fresh data (hours)
        "cache_ttl_hours": 24,

        # ── Data Quality ──────────────────────────────────────────────────────
        # Remove papers that appear more than once in results
        "deduplicate": True,

        # Try CrossRef API to get missing volume/issue/page numbers
        # Makes references more complete but adds extra API calls (slower)
        # NOTE: Even CrossRef data can be incomplete
        "crossref_fallback": False,

        # ── History ───────────────────────────────────────────────────────────
        # Save a log of all searches to a file for reference
        "save_search_history": True,
        "history_file": "search_history.json",

        # ── Network ───────────────────────────────────────────────────────────
        # How many seconds to wait for API before giving up
        "timeout_seconds": 15,

        # How many times to retry if a request fails
        "retry_attempts": 3,

        # How many seconds to wait between retries
        "retry_delay_seconds": 2,

        # ── Display ───────────────────────────────────────────────────────────
        # Show extra debug info in terminal output
        "verbose": False,

        # Max authors to show in references (rest become "et al.")
        "max_authors_display": 3,
    }

    try:
        with open("config.json", "r") as f:
            user_config = json.load(f)
        defaults.update(user_config)
    except FileNotFoundError:
        print("⚠️  config.json not found — using built-in defaults")
        print("   Create config.json to customize settings\n")
    except json.JSONDecodeError as e:
        print(f"⚠️  config.json syntax error: {e}")
        print("   Using built-in defaults\n")

    return defaults


# Load config once at startup — all modules use these variables
config = load_config()

BASE_URL           = config["base_url"]
PER_PAGE           = config["per_page"]
MAX_PAGES          = config["max_pages"]
TEXT_MODE          = config["text_mode"]
MATCH_MODE         = config["match_mode"]
MIN_WORD_COUNT     = config["min_word_count"]
MAX_BLOCKS         = config["max_blocks_per_source"]
YEAR_MIN           = config["year_min"]
YEAR_MAX           = config["year_max"]
MIN_CITATIONS      = config["min_citation_count"]
SORT_BY            = config["sort_by"]
OUTPUT_FILE        = config["output_file"]
EXPORT_FORMATS     = config["export_formats"]
CACHE_ENABLED      = config["cache_enabled"]
CACHE_DIR          = config["cache_dir"]
CACHE_TTL          = config["cache_ttl_hours"] * 3600  # convert hours → seconds
DEDUPLICATE        = config["deduplicate"]
FETCH_OA_URL       = config["fetch_open_access_url"]
CONCEPTS_FILTER    = config["concepts_filter"]
AUTHOR_FILTER      = config["author_filter"]
INSTITUTION_FILTER = config["institution_filter"]
OPEN_ACCESS_ONLY   = config["open_access_only"]
LANGUAGE_FILTER    = config["language_filter"]
POLITE_EMAIL       = config["polite_email"]
TIMEOUT            = config["timeout_seconds"]
RETRY_ATTEMPTS     = config["retry_attempts"]
RETRY_DELAY        = config["retry_delay_seconds"]
VERBOSE            = config["verbose"]
SAVE_HISTORY       = config["save_search_history"]
HISTORY_FILE       = config["history_file"]
MAX_AUTHORS        = config["max_authors_display"]
INCLUDE_ABSTRACT   = config["include_abstract_full"]
MIN_ABSTRACT_WORDS = config["min_abstract_words"]
CROSSREF_FALLBACK  = config["crossref_fallback"]



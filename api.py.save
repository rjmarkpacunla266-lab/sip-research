# ─── CACHE ──────────────────────────────────────────────────────────────────────
# Cache stores API responses as local files
# Benefit: Repeated identical searches are instant and free

def get_cache_path(key):
    """Convert a cache key into a unique file path using MD5 hash."""
    os.makedirs(CACHE_DIR, exist_ok=True)
    h = hashlib.md5(key.encode()).hexdigest()
    return os.path.join(CACHE_DIR, f"{h}.json")


def load_cache(key):
    """
    Load a cached API response if it exists and hasn't expired.
    Returns None if cache miss, disabled, or expired.
    Cache expiry is set by cache_ttl_hours in config.json.
    """
    if not CACHE_ENABLED:
        return None
    path = get_cache_path(key)
    if os.path.exists(path):
        age = time.time() - os.path.getmtime(path)
        if age < CACHE_TTL:
            try:
                with open(path) as f:
                    data = json.load(f)
                if VERBOSE:
                    print(f"  📦 Cache hit (age: {int(age/3600)}h {int((age%3600)/60)}m)")
                return data
            except (json.JSONDecodeError, IOError):
                pass  # corrupted cache — ignore and re-fetch
    return None


def save_cache(key, data):
    """Save API response to cache file for future reuse."""
    if not CACHE_ENABLED:
        return
    try:
        with open(get_cache_path(key), "w") as f:
            json.dump(data, f)
    except IOError as e:
        logger.warning(f"Cache write failed: {e}")


def clear_cache():
    """Delete all cache files. Run with: python api.py --clear-cache"""
    if not os.path.exists(CACHE_DIR):
        print("  Cache folder not found — nothing to clear")
        return
    count = 0
    for fname in os.listdir(CACHE_DIR):
        if fname.endswith(".json"):
            os.remove(os.path.join(CACHE_DIR, fname))
            count += 1
    print(f"  ✓ Cleared {count} cached files from {CACHE_DIR}/")


def get_cache_stats():
    """Return cache size info. Run with: python api.py --cache-stats"""
    if not os.path.exists(CACHE_DIR):
        return {"files": 0, "size_kb": 0}
    files = [f for f in os.listdir(CACHE_DIR) if f.endswith(".json")]
    total_bytes = sum(
        os.path.getsize(os.path.join(CACHE_DIR, f)) for f in files
    )
    return {"files": len(files), "size_kb": round(total_bytes / 1024, 1)}


# ─── SEARCH HISTORY ─────────────────────────────────────────────────────────────
# Logs every search to a JSON file so you can track what you've searched

def save_to_history(query, block_count, paper_count):
    """
    Append this search to search_history.json.
    Includes query, date, result counts, and filters used.
    View history with: python api.py --history
    """
    if not SAVE_HISTORY:
        return
    history = []
    if os.path.exists(HISTORY_FILE):
        try:
            with open(HISTORY_FILE) as f:
                history = json.load(f)
        except Exception:
            history = []

    history.append({
        "query":        query,
        "date":         datetime.now().isoformat(),
        "blocks_found": block_count,
        "papers_found": paper_count,
        "filters": {
            "year_min":      YEAR_MIN,
            "year_max":      YEAR_MAX,
            "min_citations": MIN_CITATIONS,
            "open_access":   OPEN_ACCESS_ONLY,
            "language":      LANGUAGE_FILTER,
            "match_mode":    MATCH_MODE,
        }
    })

    try:
        with open(HISTORY_FILE, "w") as f:
            json.dump(history, f, indent=2)
    except IOError as e:
        logger.warning(f"Could not save history: {e}")


def print_history():
    """Print the 10 most recent searches. Use: python api.py --history"""
    if not os.path.exists(HISTORY_FILE):
        print("  No search history found yet.")
        return
    try:
        with open(HISTORY_FILE) as f:
            history = json.load(f)
        recent = history[-10:][::-1]
        print(f"\n📋 Last {len(recent)} searches:\n")
        print(f"  {'Date':<12} {'Blocks':>6} {'Papers':>6}  Query")
        print(f"  {'─'*12} {'─'*6} {'─'*6}  {'─'*30}")
        for e in recent:
            date = e.get("date", "")[:10]
            b    = e.get("blocks_found", 0)
            p    = e.get("papers_found", 0)
            q    = e.get("query", "")
            print(f"  {date:<12} {b:>6} {p:>6}  {q}")
        print()
    except Exception as e:
        print(f"  Could not read history file: {e}")


# ─── ABSTRACT RECONSTRUCTION ────────────────────────────────────────────────────

def reconstruct_abstract(abstract_index):
    """
    Convert OpenAlex inverted index format back into readable text.

    OpenAlex stores abstracts as an inverted index to save space:
      {"word": [position1, position2], "another": [position3], ...}

    This function reverses that into the original word order.
    Result may have minor differences from the original due to tokenization.

    Returns empty string if abstract is not available.
    Note: Many papers have no abstract due to publisher restrictions.
    """
    if not abstract_index:
        return ""
    word_positions = []
    for word, positions in abstract_index.items():
        for pos in positions:
            word_positions.append((pos, word))
    word_positions.sort(key=lambda x: x[0])
    return " ".join(w for _, w in word_positions)


# ─── TEXT SPLITTING ─────────────────────────────────────────────────────────────

def split_text(text):
    """
    Split abstract text into blocks for keyword matching.

    Mode behavior (set text_mode in config.json):
    - paragraph: splits on newline characters \\n
    - sentence:  splits after . ! ? followed by space
    - full:      returns entire abstract as single block

    'paragraph' mode is recommended for most academic abstracts
    since they are structured paragraphs.
    """
    if not text:
        return []
    if TEXT_MODE == "paragraph":
        return [p.strip() for p in text.split("\n") if p.strip()]
    elif TEXT_MODE == "sentence":
        sentences = re.split(r'(?<=[.!?]) +', text)
        return [s.strip() for s in sentences if s.strip()]
    else:  # full
        return [text.strip()]


# ─── KEYWORD MATCHING ───────────────────────────────────────────────────────────

def keyword_match(block, keywords):
    """
    Check if a text block contains the search keywords.

    Match modes (set match_mode in config.json):
    - all:    block must contain EVERY keyword (strict, fewer results)
    - any:    block must contain AT LEAST ONE keyword (loose, more results)
    - phrase: block must contain keywords in exact order as typed

    Keywords are matched case-insensitively.
    """
    block_lower = block.lower()
    if MATCH_MODE == "any":
        return any(k in block_lower for k in keywords)
    elif MATCH_MODE == "phrase":
        return " ".join(keywords) in block_lower
    else:  # all (default — most useful for research)
        return all(k in block_lower for k in keywords)


def filter_blocks(blocks, keywords):
    """
    Filter text blocks by length and keyword match.
    Blocks shorter than min_word_count are always discarded.
    Returns list of blocks that pass both filters.
    """
    results = []
    for block in blocks:
        if len(block.split()) < MIN_WORD_COUNT:
            continue  # too short — skip
        if keyword_match(block, keywords):
            results.append(block.strip())
    return results


# ─── PAPER FILTERING ────────────────────────────────────────────────────────────

def filter_paper(paper):
    """
    Decide whether to include a paper based on config filters.

    Returns True  = include this paper
    Returns False = skip this paper

    Filters applied:
    1. Must have a publication year
    2. Year must be within year_min – year_max range
    3. Citation count must be >= min_citation_count
    4. Must be open access if open_access_only = true
    5. Must match language if language_filter is set
    """
    year      = paper.get("publication_year")
    citations = paper.get("cited_by_count", 0)

    if not year:
        return False  # skip papers with unknown year

    if YEAR_MIN and year < YEAR_MIN:
        return False

    if YEAR_MAX and year > YEAR_MAX:
        return False

    if citations < MIN_CITATIONS:
        return False

    if OPEN_ACCESS_ONLY:
        oa = paper.get("open_access") or {}
        if not oa.get("is_oa", False):
            return False

    if LANGUAGE_FILTER:
        lang = paper.get("language", "")
        if lang and lang != LANGUAGE_FILTER:
            return False

    return True


# ─── REFERENCE FORMATTING ───────────────────────────────────────────────────────
#
# ⚠️  IMPORTANT DISCLAIMER ABOUT THESE FUNCTIONS:
#
# These functions generate citation references AUTOMATICALLY from API metadata.
# They are approximations and will frequently be INCOMPLETE or slightly wrong.
#
# Most common issues:
#   1. Volume and issue numbers → usually MISSING (OpenAlex doesn't store them well)
#   2. Page numbers → usually MISSING
#   3. Author name format → approximate (we convert "John Smith" to "Smith, J.")
#      but non-Western names, hyphenated names, and suffixes (Jr., III) may fail
#   4. Journal name → sometimes abbreviated, sometimes full, inconsistent
#   5. DOIs → usually correct but may be missing for older papers
#
# What to do:
#   - Use generated references as a STARTING POINT only
#   - Open the paper's DOI link and verify all fields
#   - For important work, use CrossRef (crossref.org) to get complete metadata
#   - Consider using Zotero or Mendeley with the imported .ris or .bib files

def format_authors_apa(paper):
    """
    Format author names in APA 7th edition style: Last, F. M.

    ⚠️  LIMITATION: OpenAlex stores full names (e.g., "John A. Smith")
    but APA requires "Smith, J. A." — our conversion handles most Western
    names but may produce incorrect results for:
      - Chinese, Japanese, Korean names (where family name comes first)
      - Names with particles (von, de, van, el)
      - Names with suffixes (Jr., Sr., III)
      - Single-name authors
      - Names with hyphens

    Always verify author formatting against the original paper.
    """
    authorships = paper.get("authorships", [])
    if not authorships:
        return "Unknown Author"

    formatted = []
    for a in authorships[:MAX_AUTHORS]:
        full_name = (a.get("author") or {}).get("display_name", "").strip()
        if not full_name:
            continue
        parts = full_name.split()
        if len(parts) >= 2:
            last     = parts[-1]
            # Build initials from all name parts except last
            initials = ". ".join(p[0].upper() for p in parts[:-1] if p) + "."
            formatted.append(f"{last}, {initials}")
        else:
            formatted.append(full_name)

    if not formatted:
        return "Unknown Author"

    # APA joining: use "&" before final author name
    if len(formatted) == 1:
        result = formatted[0]
    elif len(formatted) == 2:
        result = f"{formatted[0]}, & {formatted[1]}"
    else:
        result = ", ".join(formatted[:-1]) + f", & {formatted[-1]}"

    # Add et al. if paper has more authors than we show
    if len(authorships) > MAX_AUTHORS:
        result += ", et al."

    return result


def format_apa(paper):
    """
    Generate APA 7th Edition reference string.

    Expected format:
      Last, F. M., & Last, F. M. (Year). Title of article.
      Journal Name, Volume(Issue), first-last page.
      https://doi.org/xxxxx

    ⚠️  WHAT IS OFTEN MISSING IN AUTO-GENERATED OUTPUT:
      - Volume number → shown only if OpenAlex has it
      - Issue number  → shown only if OpenAlex has it
      - Page range    → shown only if OpenAlex has it
      (These are missing for most papers in OpenAlex)

    Data source: OpenAlex metadata (may differ from CrossRef or publisher)
    """
    authors = format_authors_apa(paper)
    year    = paper.get("publication_year", "n.d.")
    title   = paper.get("title", "No Title Available")

    # Safely get journal name — primary_location and source can both be None
    journal = (
        (paper.get("primary_location") or {})
        .get("source") or {}
    ).get("display_name", "")

    # Get volume, issue, pages from biblio field (often empty)
    biblio = paper.get("biblio") or {}
    volume = biblio.get("volume", "")
    issue  = biblio.get("issue", "")
    p1     = biblio.get("first_page", "")
    p2     = biblio.get("last_page", "")
    pages  = f"{p1}–{p2}" if p1 and p2 else p1

    doi = paper.get("doi", "")
    url = doi if doi else paper.get("id", "")

    # Build reference piece by piece
    ref = f"{authors} ({year}). {title}."
    if journal:
        ref += f" {journal}"
        if volume:
            ref += f", {volume}"
            if issue:
                ref += f"({issue})"
        if pages:
            ref += f", {pages}"
        ref += "."
    if url:
        ref += f" {url}"

    return ref


def format_mla(paper):
    """
    Generate MLA 9th Edition reference string.

    Expected format:
      Last, First, and First Last. "Title of Article."
      Journal Name, vol. X, no. X, Year, pp. XX-XX.

    ⚠️  Same limitations as APA — volume, issue, pages often missing.
    MLA requires specific punctuation that may not be perfectly reproduced.
    """
    authorships = paper.get("authorships", [])
    year        = paper.get("publication_year", "n.d.")
    title       = paper.get("title", "No Title")
    journal     = (
        (paper.get("primary_location") or {})
        .get("source") or {}
    ).get("display_name", "")
    doi    = paper.get("doi", "")
    biblio = paper.get("biblio") or {}

    # MLA: "Last, First" for first author, "First Last" for rest
    if authorships:
        first_name = (authorships[0].get("author") or {}).get("display_name", "")
        parts = first_name.split()
        if len(parts) >= 2:
            first_fmt = f"{parts[-1]}, {' '.join(parts[:-1])}"
        else:
            first_fmt = first_name

        other_names = []
        for a in authorships[1:MAX_AUTHORS]:
            n = (a.get("author") or {}).get("display_name", "")
            if n:
                other_names.append(n)

        if other_names:
            author_str = first_fmt + ", and " + ", and ".join(other_names)
            if len(authorships) > MAX_AUTHORS:
                author_str += ", et al"
        else:
            author_str = first_fmt
            if len(authorships) > 1:
                author_str += ", et al"
    else:
        author_str = "Unknown"

    ref = f'{author_str}. "{title}." {journal}'
    if biblio.get("volume"):
        ref += f', vol. {biblio["volume"]}'
    if biblio.get("issue"):
        ref += f', no. {biblio["issue"]}'
    ref += f", {year}"
    if biblio.get("first_page"):
        p = biblio["first_page"]
        if biblio.get("last_page"):
            p += f'-{biblio["last_page"]}'
        ref += f", pp. {p}"
    if doi:
        ref += f". {doi}"
    ref += "."
    return ref


def format_bibtex(paper):
    """
    Generate a BibTeX entry for LaTeX documents.

    Usage: Copy into your .bib file, then cite with \\cite{key}
    The citation key is the OpenAlex work ID (e.g., W2123456789)

    ⚠️  volume, number, pages fields are often empty.
    Fill them in manually by looking up the paper's DOI.
    """
    pid     = (paper.get("id") or "").split("/")[-1] or "ref_unknown"
    year    = paper.get("publication_year", "")
    title   = paper.get("title", "")
    journal = (
        (paper.get("primary_location") or {})
        .get("source") or {}
    ).get("display_name", "")
    doi     = paper.get("doi", "")
    cites   = paper.get("cited_by_count", 0)
    biblio  = paper.get("biblio") or {}

    # BibTeX author format: "First Last and First Last and ..."
    authors = " and ".join(
        (a.get("author") or {}).get("display_name", "")
        for a in paper.get("authorships", [])
        if (a.get("author") or {}).get("display_name")
    )

    lines = [
        f"@article{{{pid},",
        f"  author  = {{{authors}}},",
        f"  year    = {{{year}}},",
        f"  title   = {{{title}}},",
        f"  journal = {{{journal}}},",
    ]
    if biblio.get("volume"):
        lines.append(f"  volume  = {{{biblio['volume']}}},")
    if biblio.get("issue"):
        lines.append(f"  number  = {{{biblio['issue']}}},")
    if biblio.get("first_page"):
        pages = biblio["first_page"]
        if biblio.get("last_page"):
            pages += f"--{biblio['last_page']}"
        lines.append(f"  pages   = {{{pages}}},")
    if doi:
        lines.append(f"  doi     = {{{doi}}},")
    lines.append(f"  note    = {{Cited {cites} times. Source: OpenAlex}}")
    lines.append("}")
    return "\n".join(lines)


def format_ris(paper):
    """
    Generate a RIS format entry.

    RIS is supported by: Zotero, Mendeley, EndNote, RefWorks, Papers
    Import the .ris file into your reference manager.

    ⚠️  Some fields like VL (volume) and IS (issue) may be empty.
    Your reference manager may prompt you to complete them.
    """
    authorships = paper.get("authorships", [])
    year        = paper.get("publication_year", "")
    title       = paper.get("title", "")
    journal     = (
        (paper.get("primary_location") or {})
        .get("source") or {}
    ).get("display_name", "")
    doi    = paper.get("doi", "")
    cites  = paper.get("cited_by_count", 0)
    biblio = paper.get("biblio") or {}

    lines = ["TY  - JOUR"]  # TY = type (JOUR = journal article)
    for a in authorships:
        name = (a.get("author") or {}).get("display_name", "")
        if name:
            lines.append(f"AU  - {name}")
    lines.append(f"PY  - {year}")
    lines.append(f"TI  - {title}")
    lines.append(f"JO  - {journal}")
    if biblio.get("volume"):
        lines.append(f"VL  - {biblio['volume']}")
    if biblio.get("issue"):
        lines.append(f"IS  - {biblio['issue']}")
    if biblio.get("first_page"):
        lines.append(f"SP  - {biblio['first_page']}")
    if biblio.get("last_page"):
        lines.append(f"EP  - {biblio['last_page']}")
    if doi:
        lines.append(f"DO  - {doi}")
    lines.append(f"N1  - Cited {cites} times (source: OpenAlex)")
    lines.append("ER  -")  # ER = end of record (required by RIS format)
    return "\n".join(lines)


# ─── CROSSREF FALLBACK ──────────────────────────────────────────────────────────
# CrossRef API often has more complete metadata than OpenAlex
# especially volume, issue, and page numbers
# Enable with: "crossref_fallback": true in config.json
# NOTE: Adds extra API calls — slower but more complete references

def fetch_crossref(doi):
    """
    Fetch additional metadata from CrossRef using a paper's DOI.

    CrossRef is a non-profit organization that assigns DOIs and
    maintains bibliographic metadata for academic papers.
    Their API is free and has no key requirement.

    Data returned: volume, issue, page numbers (if available)

    ⚠️  Even CrossRef data is sometimes incomplete or incorrect.
    Always verify references from original sources.
    """
    if not doi or not CROSSREF_FALLBACK:
        return {}

    # Remove URL prefix from DOI if present
    clean_doi = doi.replace("https://doi.org/", "").replace("http://doi.org/", "")
    url = f"https://api.crossref.org/works/{clean_doi}"

    # CrossRef prefers tools to identify themselves via User-Agent
    email = POLITE_EMAIL or "anonymous"
    headers = {"User-Agent": f"SIP-Tool/4.0 (mailto:{email})"}

    cache_key = f"crossref:{clean_doi}"
    cached = load_cache(cache_key)
    if cached:
        return cached

    try:
        resp = requests.get(url, headers=headers, timeout=10)
        if resp.status_code == 200:
            msg = resp.json().get("message", {})
            result = {
                "volume": msg.get("volume", ""),
                "issue":  msg.get("issue", ""),
                "page":   msg.get("page", ""),
            }
            save_cache(cache_key, result)
            return result
    except Exception:
        pass  # CrossRef is optional — always silently fail

    return {}


# ─── OPENALEX API ───────────────────────────────────────────────────────────────

def build_headers():
    """
    Build HTTP headers for OpenAlex API requests.

    The 'polite pool' is OpenAlex's way of rewarding tools that
    identify themselves — they get higher rate limits and priority.
    Add your email to polite_email in config.json to enable this.

    See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
    """
    headers = {"Accept": "application/json"}
    if POLITE_EMAIL:
        headers["User-Agent"] = f"SIP-Research-Tool/4.0 (mailto:{POLITE_EMAIL})"
    return headers


def build_params(query, page=1):
    """
    Build URL query parameters for the OpenAlex API request.

    OpenAlex uses a filter string syntax like:
      filter=publication_year:>2019,cited_by_count:>100,is_oa:true

    Multiple filters are separated by commas.
    Full API docs: https://docs.openalex.org/api-entities/works/filter-works
    """
    params = {
        "search":   query,
        "per-page": PER_PAGE,
        "page":     page,
        "sort":     SORT_BY,
    }

    filters = []

    # Year range (OpenAlex uses > and < operators)
    if YEAR_MIN:
        filters.append(f"publication_year:>{YEAR_MIN - 1}")
    if YEAR_MAX:
        filters.append(f"publication_year:<{YEAR_MAX + 1}")

    # Citation count minimum
    if MIN_CITATIONS:
        filters.append(f"cited_by_count:>{MIN_CITATIONS - 1}")

    # Open access only
    if OPEN_ACCESS_ONLY:
        filters.append("is_oa:true")

    # Language (ISO 639-1 code, e.g., "en", "fr", "es")
    if LANGUAGE_FILTER:
        filters.append(f"language:{LANGUAGE_FILTER}")

    # Author name search
    if AUTHOR_FILTER:
        filters.append(f"authorships.author.display_name.search:{AUTHOR_FILTER}")

    # Institution name search
    if INSTITUTION_FILTER:
        filters.append(f"authorships.institutions.display_name.search:{INSTITUTION_FILTER}")

    # Concept/topic tags
    for concept in CONCEPTS_FILTER:
        filters.append(f"concepts.display_name.search:{concept}")

    if filters:
        params["filter"] = ",".join(filters)

    return params


def fetch_page(query, page=1):
    """
    Fetch one page of results from OpenAlex API.

    Features:
    - Checks cache first (returns instantly if cached)
    - Retries up to RETRY_ATTEMPTS times on failure
    - Handles rate limiting (HTTP 429) with automatic wait
    - Returns None on complete failure (tool continues gracefully)

    Rate limits: 100k requests/day without email, more with polite_email
    """
    # Build unique cache key for this exact request
    cache_key = (
        f"openalex:{query}|p{page}|{YEAR_MIN}-{YEAR_MAX}|"
        f"{MIN_CITATIONS}|{OPEN_ACCESS_ONLY}|{LANGUAGE_FILTER}|"
        f"{AUTHOR_FILTER}|{SORT_BY}|{PER_PAGE}"
    )
    cached = load_cache(cache_key)
    if cached:
        return cached

    params  = build_params(query, page)
    headers = build_headers()

    # Retry loop
    for attempt in range(1, RETRY_ATTEMPTS + 1):
        try:
            resp = requests.get(
                BASE_URL,
                params=params,
                headers=headers,
                timeout=TIMEOUT
            )

            # Rate limit hit — wait and retry
            if resp.status_code == 429:
                wait_time = int(resp.headers.get("Retry-After", 30))
                print(f"  ⏳ Rate limited by OpenAlex — waiting {wait_time}s...")
                time.sleep(wait_time)
                continue

            resp.raise_for_status()
            data = resp.json()
            save_cache(cache_key, data)
            return data

        except requests.exceptions.Timeout:
            print(f"  ⚠️  Request timed out (attempt {attempt}/{RETRY_ATTEMPTS})")
        except requests.exceptions.ConnectionError:
            print(f"  ⚠️  No internet connection (attempt {attempt}/{RETRY_ATTEMPTS})")
        except requests.exceptions.HTTPError as e:
            print(f"  ⚠️  HTTP error {e.response.status_code}: {e}")
            break  # Don't retry client errors (4xx)
        except Exception as e:
            print(f"  ⚠️  Unexpected error: {e}")

        if attempt < RETRY_ATTEMPTS:
            print(f"  Retrying in {RETRY_DELAY}s...")
            time.sleep(RETRY_DELAY)

    return None  # All attempts failed


def fetch_all_pages(query):
    """
    Fetch multiple pages of results from OpenAlex.

    Maximum papers = MAX_PAGES × PER_PAGE (configured in config.json)
    OpenAlex has millions of papers — this fetches a sample sorted by
    the SORT_BY setting (default: most cited first).

    The function:
    1. Fetches page 1 to get total result count
    2. Calculates how many more pages to fetch
    3. Fetches remaining pages with small delays (polite)
    4. Returns all results combined
    """
    all_results   = []
    pages_fetched = 0

    # Fetch first page
    print(f"  Fetching page 1...", end="\r")
    first = fetch_page(query, 1)

    if not first:
        print("  ✗ Failed to get results from OpenAlex API")
        print("    Check your internet connection and try again")
        return []

    total_in_openalex = first.get("meta", {}).get("count", 0)
    all_results.extend(first.get("results", []))
    pages_fetched = 1

    # Calculate remaining pages to fetch
    pages_possible = max(1, (total_in_openalex // PER_PAGE) + 1)
    pages_to_fetch = min(MAX_PAGES, pages_possible)

    # Fetch remaining pages
    for page_num in range(2, pages_to_fetch + 1):
        print(f"  Fetching page {page_num}/{pages_to_fetch}...", end="\r")
        data = fetch_page(query, page_num)

        if not data:
            print(f"  ⚠️  Could not fetch page {page_num} — using results so far")
            break

        results = data.get("results", [])
        if not results:
            break  # empty page = no more results

        all_results.extend(results)
        pages_fetched += 1
        time.sleep(0.1)  # small delay — be polite to the API

    print(
        f"  ✓ Fetched {len(all_results)} papers from {pages_fetched} page(s)  "
        f"(OpenAlex has {total_in_openalex:,} total results for this query)"
    )
    return all_results


# ─── DEDUPLICATION ──────────────────────────────────────────────────────────────

def deduplicate_papers(papers):
    """
    Remove duplicate papers using OpenAlex ID.
    Duplicates can happen when the same paper appears on multiple pages.
    Papers without an ID are kept (edge case).
    """
    seen_ids = set()
    unique   = []
    for paper in papers:
        pid = paper.get("id", "")
        if pid and pid in seen_ids:
            continue  # skip duplicate
        if pid:
            seen_ids.add(pid)
        unique.append(paper)
    return unique


# ─── CONCEPT EXTRACTION ─────────────────────────────────────────────────────────

def extract_concepts(paper, top_n=5):
    """
    Get the top topic/concept tags for a paper.

    OpenAlex automatically assigns concepts using machine learning.
    Each concept has a score from 0 to 1 (confidence).
    We return the top N concepts by score.

    Note: These are AI-generated tags — occasionally incorrect.
    They are useful for filtering and visualization but not for
    official classification of a paper's topic.
    """
    concepts = paper.get("concepts") or []
    top = sorted(concepts, key=lambda c: c.get("score", 0), reverse=True)[:top_n]
    return [c.get("display_name", "") for c in top if c.get("display_name")]


# ─── STATISTICS ─────────────────────────────────────────────────────────────────

def compute_stats(papers):
    """
    Compute summary statistics for a collection of papers.

    Returns a dictionary with:
    - total_papers, year_range, citation stats
    - open_access_count, abstract_count
    - top journals, top concepts, year distribution

    These stats are shown in terminal output and embedded in exports.
    Note: Stats are based on OpenAlex metadata which may be incomplete.
    """
    if not papers:
        return {}

    years     = [p.get("publication_year") for p in papers if p.get("publication_year")]
    citations = [p.get("cited_by_count", 0) for p in papers]

    # Count journals
    journal_counter = defaultdict(int)
    for p in papers:
        j = (
            (p.get("primary_location") or {})
            .get("source") or {}
        ).get("display_name", "")
        if j:
            journal_counter[j] += 1

    # Count concepts
    concept_counter = defaultdict(int)
    for p in papers:
        for c in extract_concepts(p):
            concept_counter[c] += 1

    # Count by year
    year_counter = defaultdict(int)
    for y in years:
        year_counter[y] += 1

    oa_count = sum(
        1 for p in papers
        if (p.get("open_access") or {}).get("is_oa", False)
    )

    abstract_count = sum(
        1 for p in papers
        if p.get("abstract_inverted_index")
    )

    return {
        "total_papers":       len(papers),
        "year_range":         [min(years), max(years)] if years else [],
        "avg_citations":      round(sum(citations) / len(citations), 1) if citations else 0,
        "max_citations":      max(citations) if citations else 0,
        "min_citations":      min(citations) if citations else 0,
        "total_citations":    sum(citations),
        "open_access_count":  oa_count,
        "has_abstract_count": abstract_count,
        "top_journals":       sorted(journal_counter.items(), key=lambda x: x[1], reverse=True)[:10],
        "top_concepts":       sorted(concept_counter.items(), key=lambda x: x[1], reverse=True)[:15],
        "year_distribution":  dict(sorted(year_counter.items())),
    }


# ─── EXPORT FUNCTIONS ───────────────────────────────────────────────────────────

def export_json(payload, path):
    """Export full results as JSON (main output file used by index.html)."""
    try:
        with open(path, "w", encoding="utf-8") as f:
            json.dump(payload, f, indent=2, ensure_ascii=False)
        print(f"  ✓ JSON     → {path}")
    except IOError as e:
        print(f"  ✗ JSON failed: {e}")


def export_csv(data, path):
    """
    Export results as CSV spreadsheet.
    Open with Excel, Google Sheets, or LibreOffice.
    List fields (authors, concepts) are joined with semicolons.
    """
    if not data:
        return
    try:
        fields = [
            "title", "authors", "year", "journal", "volume", "issue",
            "pages", "citations", "is_oa", "language", "text",
            "apa_reference", "mla_reference", "doi", "oa_url",
            "concepts", "openalex_id"
        ]
        with open(path, "w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=fields, extrasaction="ignore")
            writer.writeheader()
            for row in data:
                flat = {}
                for k in fields:
                    v = row.get(k, "")
                    flat[k] = "; ".join(str(i) for i in v) if isinstance(v, list) else v
                writer.writerow(flat)
        print(f"  ✓ CSV      → {path}")
    except IOError as e:
        print(f"  ✗ CSV failed: {e}")


def export_bibtex(papers, path):
    """
    Export all papers as BibTeX (.bib file).
    Import into LaTeX, Zotero, or Mendeley.
    ⚠️  Many entries will have missing volume/issue/pages.
    """
    try:
        header = (
            "% ═══════════════════════════════════════════════════════════\n"
            "% BibTeX file generated by SIP Tool v4.0\n"
            "% Data source: OpenAlex (openalex.org)\n"
            "%\n"
            "% ⚠️  WARNING: Auto-generated — may be INCOMPLETE\n"
            "% Volume, issue, and page numbers are often MISSING\n"
            "% Always verify each entry before academic submission\n"
            "% Cross-check at: https://crossref.org\n"
            f"% Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n"
            "% ═══════════════════════════════════════════════════════════\n\n"
        )
        entries = [format_bibtex(p) for p in papers]
        with open(path, "w", encoding="utf-8") as f:
            f.write(header + "\n\n".join(entries))
        print(f"  ✓ BibTeX   → {path}")
    except IOError as e:
        print(f"  ✗ BibTeX failed: {e}")


def export_ris(papers, path):
    """
    Export as RIS format (Zotero, Mendeley, EndNote compatible).
    ⚠️  Volume/issue/pages may be empty — verify after importing.
    """
    try:
        header = (
            "# RIS file generated by SIP Tool v4.0\n"
            "# Data source: OpenAlex (openalex.org)\n"
            "# ⚠️  Auto-generated — verify before academic use\n"
            f"# Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n"
        )
        entries = [format_ris(p) for p in papers]
        with open(path, "w", encoding="utf-8") as f:
            f.write(header + "\n\n".join(entries))
        print(f"  ✓ RIS      → {path}")
    except IOError as e:
        print(f"  ✗ RIS failed: {e}")


def export_txt(data, path):
    """Export as plain text — readable in any editor."""
    try:
        with open(path, "w", encoding="utf-8") as f:
            f.write("═" * 60 + "\n")
            f.write("SIP RESEARCH RESULTS — Plain Text Export\n")
            f.write("═" * 60 + "\n")
            f.write(f"Generated : {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")
            f.write(f"Source    : OpenAlex (openalex.org)\n")
            f.write(f"Records   : {len(data)}\n")
            f.write("⚠️  References auto-generated — verify before academic use\n")
            f.write("═" * 60 + "\n\n")

            for i, item in enumerate(data, 1):
                authors = ", ".join(item.get("authors", [])[:3])
                if len(item.get("authors", [])) > 3:
                    authors += " et al."
                f.write(f"[{i}] {item.get('title', 'Untitled')}\n")
                f.write(f"    Authors  : {authors}\n")
                f.write(f"    Year     : {item.get('year', '?')}\n")
                f.write(f"    Journal  : {item.get('journal', 'Unknown')}\n")
                f.write(f"    Citations: {item.get('citations', 0):,}\n")
                f.write(f"    Open Access: {'Yes' if item.get('is_oa') else 'No'}\n")
                if item.get("oa_url"):
                    f.write(f"    Full Text: {item['oa_url']}\n")
                f.write(f"\n    EXTRACTED TEXT:\n")
                # Word-wrap text at 70 chars
                words = item.get("text", "").split()
                line  = "    "
                for word in words:
                    if len(line) + len(word) > 74:
                        f.write(line + "\n")
                        line = "    " + word + " "
                    else:
                        line += word + " "
                if line.strip():
                    f.write(line + "\n")
                f.write(f"\n    APA (auto-generated — verify):\n")
                f.write(f"    {item.get('apa_reference', 'Not available')}\n")
                f.write(f"\n    MLA (auto-generated — verify):\n")
                f.write(f"    {item.get('mla_reference', 'Not available')}\n")
                f.write("\n" + "─" * 60 + "\n\n")
        print(f"  ✓ TXT      → {path}")
    except IOError as e:
        print(f"  ✗ TXT failed: {e}")


def export_markdown(data, stats, query, path):
    """
    Export as Markdown — readable in Notion, Obsidian, GitHub, VS Code.
    Includes full metadata tables and reference notes.
    """
    try:
        lines = [
            "# SIP Research Export",
            "",
            "> **Data Source:** OpenAlex (openalex.org) — free, open academic database  ",
            "> **⚠️ Reference Disclaimer:** References below are auto-generated from API metadata.",
            "> Volume, issue, and page numbers are frequently missing.",
            "> **Always verify citations manually before academic submission.**",
            "> Cross-check at: [CrossRef](https://crossref.org) or the publisher's website.",
            "",
            "---",
            "",
            f"**Query:** `{query}`  ",
            f"**Generated:** {datetime.now().strftime('%Y-%m-%d %H:%M')}  ",
            f"**Total blocks:** {len(data)}  ",
            f"**Total papers:** {stats.get('total_papers', 0)}  ",
            "",
            "---",
            "",
            "## 📊 Summary Statistics",
            "",
            "> *Based on OpenAlex metadata — may differ from other databases*",
            "",
        ]

        yr = stats.get("year_range", [])
        if yr:
            lines.append(f"- **Year range:** {yr[0]} – {yr[-1]}")
        lines.append(f"- **Avg citations:** {stats.get('avg_citations', 0):,}")
        lines.append(f"- **Max citations:** {stats.get('max_citations', 0):,}")
        lines.append(f"- **Open access papers:** {stats.get('open_access_count', 0)}")
        lines.append(f"- **Papers with abstracts:** {stats.get('has_abstract_count', 0)}")

        if stats.get("top_journals"):
            j_str = ", ".join(j for j, _ in stats["top_journals"][:5] if j)
            lines.append(f"- **Top journals:** {j_str}")

        if stats.get("top_concepts"):
            c_str = ", ".join(c for c, _ in stats["top_concepts"][:8])
            lines.append(f"- **Top concepts:** {c_str}")

        lines += ["", "---", "", "## 📄 Results", ""]

        for i, item in enumerate(data, 1):
            authors = ", ".join(item.get("authors", [])[:3])
            if len(item.get("authors", [])) > 3:
                authors += " et al."

            lines.append(f"### {i}. {item.get('title', 'Untitled')}")
            lines.append("")
            lines.append("| Field | Value |")
            lines.append("|:------|:------|")
            lines.append(f"| Authors | {authors} |")
            lines.append(f"| Year | {item.get('year', '?')} |")
            lines.append(f"| Journal | {item.get('journal', '?')} |")
            if item.get("volume"):
                lines.append(f"| Volume | {item['volume']} |")
            if item.get("issue"):
                lines.append(f"| Issue | {item['issue']} |")
            if item.get("pages"):
                lines.append(f"| Pages | {item['pages']} |")
            lines.append(f"| Citations | {item.get('citations', 0):,} |")
            lines.append(f"| Open Access | {'✅ Yes' if item.get('is_oa') else '❌ No'} |")
            if item.get("language"):
                lines.append(f"| Language | {item['language']} |")
            lines.append("")

            lines.append("**Extracted Text:**")
            lines.append(f"> {item.get('text', '')}")
            lines.append("")

            if item.get("concepts"):
                tags = " ".join(f"`{c}`" for c in item["concepts"])
                lines.append(f"**Concepts:** {tags}")
                lines.append("")

            if item.get("oa_url"):
                lines.append(f"🔓 [Read Full Paper (Open Access)]({item['oa_url']})")
            if item.get("doi"):
                lines.append(f"🔗 [DOI: {item['doi']}]({item['doi']})")
            lines.append("")

            lines.append("**APA Reference** *(auto-generated — volume/issue/pages may be missing — verify before use)*:")
            lines.append(f"> {item.get('apa_reference', 'Not available')}")
            lines.append("")
            lines.append("**MLA Reference** *(auto-generated — verify before use)*:")
            lines.append(f"> {item.get('mla_reference', 'Not available')}")
            lines.append("")
            lines.append("---")
            lines.append("")

        with open(path, "w", encoding="utf-8") as f:
            f.write("\n".join(lines))
        print(f"  ✓ Markdown → {path}")
    except IOError as e:
        print(f"  ✗ Markdown failed: {e}")


# ─── MAIN ────────────────────────────────────────────────────────────────────────

def main():
    """
    Main entry point — handles CLI arguments and runs the full pipeline:
    1. Parse arguments
    2. Fetch papers from OpenAlex
    3. Deduplicate and filter
    4. Extract matching text blocks
    5. Generate references
    6. Export to selected formats

    USAGE EXAMPLES:
      python api.py                                    # interactive prompt
      python api.py "starch digestion"                 # direct query
      python api.py "starch" --year-min 2015           # with year filter
      python api.py "starch" --open-access             # OA papers only
      python api.py "starch" --min-citations 500       # high impact only
      python api.py "starch" --author "Smith"          # filter by author
      python api.py "starch" --formats json csv txt    # specific formats
      python api.py "starch" --no-cache                # skip cache
      python api.py "starch" --stats-only              # stats without export
      python api.py --history                          # show past searches
      python api.py --clear-cache                      # delete cached files
      python api.py --cache-stats                      # show cache size
    """
    parser = argparse.ArgumentParser(
        description="SIP — Scientific Information Puller v4.0\nData source: OpenAlex (openalex.org)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Note: References are auto-generated. Always verify before academic use."
    )

    parser.add_argument("query",
        nargs="?",
        help="Search keywords (will prompt if not provided)")
    parser.add_argument("--formats", nargs="+", metavar="FMT",
        help="Export formats: json csv bibtex ris markdown txt")
    parser.add_argument("--year-min",      type=int, help="Minimum publication year")
    parser.add_argument("--year-max",      type=int, help="Maximum publication year")
    parser.add_argument("--min-citations", type=int, help="Minimum citation count")
    parser.add_argument("--open-access",   action="store_true", help="Only open access papers")
    parser.add_argument("--author",        help="Filter by author name (partial match)")
    parser.add_argument("--institution",   help="Filter by institution (partial match)")
    parser.add_argument("--no-cache",      action="store_true", help="Bypass cache, fetch fresh")
    parser.add_argument("--clear-cache",   action="store_true", help="Clear all cache and exit")
    parser.add_argument("--cache-stats",   action="store_true", help="Show cache info and exit")
    parser.add_argument("--stats-only",    action="store_true", help="Show stats, don't export")
    parser.add_argument("--history",       action="store_true", help="Show search history and exit")
    parser.add_argument("--verbose",       action="store_true", help="Detailed terminal output")

    args = parser.parse_args()

    # ── Handle utility commands (no search needed) ────────────────────────────
    if args.clear_cache:
        clear_cache()
        return
    if args.cache_stats:
        s = get_cache_stats()
        print(f"\n📦 Cache: {s['files']} files, {s['size_kb']} KB stored in {CACHE_DIR}/\n")
        return
    if args.history:
        print_history()
        return

    # ── Apply CLI overrides (these override config.json settings) ────────────
    global YEAR_MIN, YEAR_MAX, MIN_CITATIONS, OPEN_ACCESS_ONLY
    global AUTHOR_FILTER, INSTITUTION_FILTER, CACHE_ENABLED, EXPORT_FORMATS, VERBOSE

    if args.year_min:      YEAR_MIN = args.year_min
    if args.year_max:      YEAR_MAX = args.year_max
    if args.min_citations: MIN_CITATIONS = args.min_citations
    if args.open_access:   OPEN_ACCESS_ONLY = True
    if args.author:        AUTHOR_FILTER = args.author
    if args.institution:   INSTITUTION_FILTER = args.institution
    if args.no_cache:      CACHE_ENABLED = False
    if args.formats:       EXPORT_FORMATS = args.formats
    if args.verbose:       VERBOSE = True

    # ── Banner ────────────────────────────────────────────────────────────────
    print_banner()

    # ── Get search query ──────────────────────────────────────────────────────
    user_input = args.query or input("Enter research keywords: ").strip()
    if not user_input:
        print("❌ No query entered. Exiting.")
        sys.exit(1)

    keywords = user_input.lower().split()

    # ── Show search config ────────────────────────────────────────────────────
    print(f"🔍 Searching: \"{user_input}\"")
    print(f"   API      : OpenAlex (openalex.org)")
    print(f"   Years    : {YEAR_MIN} – {YEAR_MAX}")
    print(f"   Min cites: {MIN_CITATIONS}")
    print(f"   OA only  : {'Yes' if OPEN_ACCESS_ONLY else 'No'}")
    print(f"   Sort     : {SORT_BY}")
    print(f"   Max fetch: {MAX_PAGES} pages × {PER_PAGE} = {MAX_PAGES * PER_PAGE} papers")
    if AUTHOR_FILTER:
        print(f"   Author   : {AUTHOR_FILTER}")
    if POLITE_EMAIL:
        print(f"   Email    : {POLITE_EMAIL} (polite pool — higher limits)")
    print()

    # ── Fetch from OpenAlex ───────────────────────────────────────────────────
    raw_papers = fetch_all_pages(user_input)
    if not raw_papers:
        print("\n❌ No results from OpenAlex. Check internet and try again.")
        sys.exit(0)

    # ── Deduplicate ───────────────────────────────────────────────────────────
    if DEDUPLICATE:
        before    = len(raw_papers)
        raw_papers = deduplicate_papers(raw_papers)
        removed   = before - len(raw_papers)
        if removed:
            print(f"  ✓ Removed {removed} duplicate(s)")

    # ── Filter ────────────────────────────────────────────────────────────────
    filtered = [p for p in raw_papers if filter_paper(p)]
    print(f"  ✓ After filters: {len(filtered)}/{len(raw_papers)} papers kept")

    if not filtered:
        print("\n⚠️  All papers filtered out.")
        print("   Tips: lower min_citation_count, widen year range, or use match_mode: 'any'")
        sys.exit(0)

    # ── Stats ─────────────────────────────────────────────────────────────────
    stats = compute_stats(filtered)
    yr    = stats.get("year_range", [])
    print(f"\n📊 Stats (from OpenAlex metadata):")
    if yr:
        print(f"   Years        : {yr[0]} – {yr[-1]}")
    print(f"   Avg citations: {stats.get('avg_citations',0):,}")
    print(f"   Max citations: {stats.get('max_citations',0):,}")
    print(f"   Open access  : {stats.get('open_access_count',0)} papers")
    print(f"   Have abstract: {stats.get('has_abstract_count',0)} papers")
    if stats.get("top_concepts"):
        top5 = ", ".join(c for c, _ in stats["top_concepts"][:5])
        print(f"   Top concepts : {top5}")
    print()

    if args.stats_only:
        print("(stats-only mode — no files saved)")
        return

    # ── Build output records ──────────────────────────────────────────────────
    output_data = []
    seen_hashes = set()  # prevent duplicate text blocks in output

    for paper in filtered:
        # Reconstruct abstract text from OpenAlex inverted index
        abstract = reconstruct_abstract(paper.get("abstract_inverted_index"))

        if not abstract:
            continue  # no abstract available

        if len(abstract.split()) < MIN_ABSTRACT_WORDS:
            continue  # abstract too short to be useful

        # Split abstract and find matching blocks
        blocks  = split_text(abstract)
        matched = filter_blocks(blocks, keywords)[:MAX_BLOCKS]
        if not matched:
            continue  # no matching blocks in this abstract

        # Collect all paper metadata
        oa       = paper.get("open_access") or {}
        biblio   = paper.get("biblio") or {}
        p1       = biblio.get("first_page", "")
        p2       = biblio.get("last_page", "")

        title       = paper.get("title", "")
        year        = paper.get("publication_year")
        citations   = paper.get("cited_by_count", 0)
        doi         = paper.get("doi", "")
        openalex_id = paper.get("id", "")
        language    = paper.get("language", "")
        is_oa       = oa.get("is_oa", False)
        oa_url      = oa.get("oa_url", "") if FETCH_OA_URL else ""
        concepts    = extract_concepts(paper)
        authors     = [
            (a.get("author") or {}).get("display_name", "")
            for a in paper.get("authorships", [])
            if (a.get("author") or {}).get("display_name")
        ]
        journal = (
            (paper.get("primary_location") or {})
            .get("source") or {}
        ).get("display_name", "")

        # Auto-generate references
        # ⚠️  These may be incomplete — always verify
        apa_ref = format_apa(paper)
        mla_ref = format_mla(paper)

        for block in matched:
            # Avoid outputting same text block twice
            h = hashlib.md5(block.encode()).hexdigest()
            if h in seen_hashes:
                continue
            seen_hashes.add(h)

            output_data.append({
                # ── Content ───────────────────────────────────────────────
                "text":     block,
                "title":    title,
                "abstract": abstract if INCLUDE_ABSTRACT else "",

                # ── Authors ───────────────────────────────────────────────
                "authors":  authors,

                # ── Publication details ───────────────────────────────────
                "year":     year,
                "journal":  journal,
                "volume":   biblio.get("volume", ""),
                "issue":    biblio.get("issue", ""),
                "pages":    f"{p1}–{p2}" if p1 and p2 else p1,
                "language": language,

                # ── Identifiers ───────────────────────────────────────────
                "doi":          doi,
                "openalex_id":  openalex_id,

                # ── Impact ────────────────────────────────────────────────
                "citations":    citations,

                # ── Access ────────────────────────────────────────────────
                "is_oa":        is_oa,
                "oa_url":       oa_url,

                # ── Classification ────────────────────────────────────────
                "concepts":     concepts,

                # ── References (AUTO-GENERATED — verify before use) ───────
                "apa_reference": apa_ref,
                "mla_reference": mla_ref,

                # ── Source info (always included for transparency) ────────
                "data_source":    "OpenAlex (openalex.org)",
                "reference_note": "Auto-generated — may be incomplete. Verify before academic use.",
            })

    # ── Results summary ───────────────────────────────────────────────────────
    print(f"✅ Found {len(output_data)} matching text blocks from {len(filtered)} papers")

    if len(output_data) == 0:
        print("\n⚠️  No text blocks matched your keywords.")
        print("   Try: match_mode: 'any' in config.json, or different keywords")
        sys.exit(0)

    # ── Show disclaimer ───────────────────────────────────────────────────────
    print_results_disclaimer()

    # ── Save to search history ────────────────────────────────────────────────
    save_to_history(user_input, len(output_data), len(filtered))

    # ── Export ────────────────────────────────────────────────────────────────
    print("💾 Saving files...\n")
    base = OUTPUT_FILE.rsplit(".", 1)[0]  # filename without extension

    for fmt in EXPORT_FORMATS:
        fmt = fmt.lower().strip()
        if fmt == "json":
            payload = {
                "meta": {
                    # Search info
                    "query":        user_input,
                    "generated":    datetime.now().isoformat(),
                    "tool":         "SIP v4.0",
                    "total_blocks": len(output_data),
                    "total_papers": len(filtered),

                    # Data source transparency
                    "data_source":  "OpenAlex API (openalex.org)",
                    "data_license": "CC0 — public domain",
                    "api_endpoint": BASE_URL,

                    # Disclaimers embedded in output file
                    "important_notes": [
                        "All data sourced from OpenAlex (openalex.org)",
                        "References are auto-generated and may be INCOMPLETE",
                        "Volume, issue, page numbers are often missing",
                        "Always verify citations before submitting academic work",
                        "OpenAlex coverage varies — not all journals are indexed",
                        "Citation counts update daily on OpenAlex",
                        "Abstracts may be missing due to publisher restrictions",
                    ],

                    # Filters used for this search
                    "filters": {
                        "year_min":        YEAR_MIN,
                        "year_max":        YEAR_MAX,
                        "min_citations":   MIN_CITATIONS,
                        "open_access_only":OPEN_ACCESS_ONLY,
                        "language":        LANGUAGE_FILTER,
                        "match_mode":      MATCH_MODE,
                        "text_mode":       TEXT_MODE,
                        "sort_by":         SORT_BY,
                    },

                    "stats": stats,
                },
                "results": output_data,
            }
            export_json(payload, OUTPUT_FILE)
        elif fmt == "csv":
            export_csv(output_data, f"{base}.csv")
        elif fmt == "bibtex":
            export_bibtex(filtered, f"{base}.bib")
        elif fmt == "ris":
            export_ris(filtered, f"{base}.ris")
        elif fmt == "markdown":
            export_markdown(output_data, stats, user_input, f"{base}.md")
        elif fmt == "txt":
            export_txt(output_data, f"{base}.txt")
        else:
            print(f"  ⚠️  Unknown format '{fmt}' — skipping")

    print(f"\n✅ Done!")
    print(f"   Open index.html in a browser to view results visually")
    print(f"   Run 'python api.py --history' to see all past searches")
    print(f"   Run 'python api.py --cache-stats' to see cache size\n")

# __lol____________________________________________________________________
# ─── RUN ────────────────────────────────────────────────────────────────────────
if __name__ == "__main__":
    main()
